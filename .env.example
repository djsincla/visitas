# Top-level .env used by docker-compose.
# For non-Docker development, see server/.env.example instead.

# REQUIRED — generate with: openssl rand -hex 64
JWT_SECRET=change-me-please

# Optional
VISITAS_PORT=3000
JWT_TTL_SECONDS=43200
LOG_LEVEL=info

# Active Directory bind password (only if AD enabled in config/auth.json)
AD_BIND_PASSWORD=

# SMTP password (only if email enabled in config/notifications.json)
SMTP_PASSWORD=

# SMS provider auth token (e.g. Twilio Auth Token)
SMS_AUTH_TOKEN=
